# Firebase web SDK configuration.
# Copy this file to `.env.local` and fill in the values from your Firebase
# project: console.firebase.google.com → Project settings → General → Your apps.
#
# These keys are read only by the web client at build time. Web SDK keys are
# public-safe (they ship in the browser bundle anyway), but we keep them out
# of source control so a forked public repo doesn't ship pre-wired to our
# project. Firestore security rules are what actually protect your data.
#
# Without these set, the app runs in a localStorage-only fallback mode,
# which is fine for local demos but won't persist progress across devices.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Set to "false" to force local-only mode even when Firebase keys are present.
VITE_FIREBASE_ENABLED=true
